# Tesseract OCR Configuration
# Update this path to match your Tesseract installation
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# OCR Language (use 'eng' for English, or 'eng+hin' for multilingual)
TESSERACT_LANG=eng

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Output directory for Excel reports
OUTPUT_DIR=output/excel

# Sample invoices directory
SAMPLE_DIR=data/samples

# LLM API Keys (Required for Step 2 semantic extraction)
GEMINI_API_KEY=your_google_gemini_api_key_here
